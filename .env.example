# Frontend (Vite)
# Leave empty when frontend + API are on the same domain (Vercel).
# For a separate API host (Render/Railway), set e.g. https://your-api.onrender.com
VITE_API_URL=

# Contact form — SMTP / Nodemailer
# Set these in Vercel → Project → Settings → Environment Variables (Production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
CONTACT_RECEIVER_EMAIL=your-email@gmail.com

# Local Express server only (not used on Vercel)
PORT=5000
CLIENT_URL=https://ifthikar-portfolio.vercel.app
